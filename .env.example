# Copy to .env.local after paybond login
PAYBOND_API_KEY=
PAYBOND_GATEWAY_URL=https://api.paybond.ai

# Optional: per-tenant, SANDBOX-ONLY Stripe test-mode charge.
# - Leave unset to use the offline deterministic mock (default; no secret required).
# - Set ONLY when your Paybond tenant/session is on sandbox — a live session refuses it.
# - Must be a Stripe TEST key (sk_test_...). Live keys (sk_live_...) are rejected (fail closed).
# STRIPE_SECRET_KEY=sk_test_...
